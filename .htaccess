RewriteEngine On

# 1. Hide .html extension: redirect external requests from page.html to /page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Resolve internal requests: if /page is requested, serve page.html if it exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# 3. Hide .php extension: redirect external requests from page.php to /page
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.+)\.php [NC]
RewriteRule ^ /%1 [R=301,L]

# 4. Resolve internal requests: if /page is requested, serve page.php if it exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]
